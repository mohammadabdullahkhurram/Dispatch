# Dispatch environment variables
# Copy to .env.local and fill in values from your Supabase project
# (Dashboard → Project Settings → API).

# --- Required ---

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key — safe for the browser; RLS enforces access
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only (used by webhook handlers; never expose to the client) ---

# Supabase service-role key — bypasses RLS, needed for the GHL webhook
# routes (app/api/webhooks/*) to insert messages/tickets on behalf of clients
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- GoHighLevel integration (docs/ghl-setup.md) ---

# Private integration token / API key for the LeadConnector API.
# Required scopes: conversations/message.write, contacts.readonly,
# contacts.write (contact create + dispatch-user tag management)
GHL_API_KEY=
# The GHL sub-account (location) id
GHL_LOCATION_ID=
# The phone number SMS replies are sent from, E.164 format e.g. +15551234567
GHL_PHONE_NUMBER=

# --- Anthropic (AI triage of call transcripts in /api/webhooks/ghl-call) ---
ANTHROPIC_API_KEY=
